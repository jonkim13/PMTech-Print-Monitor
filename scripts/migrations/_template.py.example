"""Template for a one-shot data migration script.

Copy this file to ``NNN_short_description.py`` (e.g.
``002_add_part_tags.py``), fill in MIGRATION_ID and DESCRIPTION, then
replace ``_perform_changes`` with the actual schema/data work.

Pattern
-------
1. Module constants declare the migration's identity.
2. ``--dry-run`` previews; ``--apply`` runs.
3. ``--apply`` refuses to run while the print-farm service is up.
4. The runner is consulted: if MIGRATION_ID is already recorded, the
   script exits 0 without touching the DB.
5. A whole-fleet snapshot is taken into ``data/recovery/<ts>/`` AND a
   per-DB ``.bak-<ts>`` is created before any writes. These are
   additive layers, not alternatives — see "Two-layer backup" below.
6. The actual changes and ``runner.record(...)`` live in a single
   transaction so registry + data commit (or roll back) together.

Two-layer backup
----------------
``.bak-<ts>`` (created by ``create_backup`` below) captures the single
DB this migration touches, sitting next to the live file. It is the
fast, targeted restore path: ``cp data/foo.db.bak-<ts> data/foo.db``.

``data/recovery/<ts>/`` (created by ``snapshot_all_dbs``) captures
EVERY DB at the moment the migration starts, in its own folder. It is
the cross-DB safety net for the case where a migration's writes have
side effects beyond its primary target — or where an operator notices
data loss only days later, after the per-DB ``.bak`` has been pruned.

Do not drop one thinking the other is redundant. The 2026-05-19
inventory incident is why both exist.

Exit codes match migration 001 for operator-script consistency:
    0  Success (or dry-run completed cleanly, or already-applied).
    1  Bad arguments.
    2  print-farm-monitor service still running on port 5001.
    3  Backup creation failed (DB untouched).
    4  Reserved (FK violation or migration-specific validation).
    5  Any other SQLite error (transaction rolled back).
"""

from __future__ import annotations

import argparse
import os
import shutil
import socket
import sqlite3
import sys
from datetime import datetime
from typing import Optional, Sequence

# Make ``app.shared.migrations`` importable when invoked from the repo
# root: ``python scripts/migrations/NNN_xxx.py``.
HERE = os.path.dirname(os.path.abspath(__file__))
REPO_ROOT = os.path.dirname(os.path.dirname(HERE))
if REPO_ROOT not in sys.path:
    sys.path.insert(0, REPO_ROOT)

from app.config.settings import load_settings  # noqa: E402
from app.shared.migrations.runner import MigrationRunner  # noqa: E402
from app.shared.snapshots.runner import snapshot_all_dbs  # noqa: E402


# ----------------------------------------------------------------------
# Migration identity — REQUIRED for every script.
# ----------------------------------------------------------------------

MIGRATION_ID = "NNN"  # e.g. "002"
DESCRIPTION = "Short one-line summary of what this migration does"

DEFAULT_DB_PATH = "data/work_orders.db"

# Exit codes
EXIT_OK = 0
EXIT_BAD_ARGS = 1
EXIT_SERVICE_RUNNING = 2
EXIT_BACKUP_FAILED = 3
EXIT_VALIDATION = 4
EXIT_SQLITE_ERROR = 5


class _Parser(argparse.ArgumentParser):
    """argparse with our exit-code convention."""

    def error(self, message: str) -> None:
        self.print_usage(sys.stderr)
        self.exit(EXIT_BAD_ARGS,
                  "{}: error: {}\n".format(self.prog, message))


# ----------------------------------------------------------------------
# Service safety — mirror of migration 001 for consistency.
# ----------------------------------------------------------------------

def is_service_running(host: str = "127.0.0.1", port: int = 5001,
                       timeout_sec: float = 1.0) -> bool:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(timeout_sec)
    try:
        return sock.connect_ex((host, port)) == 0
    finally:
        sock.close()


# ----------------------------------------------------------------------
# Backup
# ----------------------------------------------------------------------

def create_backup(db_path: str) -> str:
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    backup_path = "{}.bak-{}".format(db_path, stamp)
    if os.path.exists(backup_path):
        raise FileExistsError(
            "Backup path already exists: {}".format(backup_path)
        )
    shutil.copy2(db_path, backup_path)
    return backup_path


# ----------------------------------------------------------------------
# Migration body
# ----------------------------------------------------------------------

def _describe_plan(conn: sqlite3.Connection) -> None:
    """Print what --apply would do. Read-only; the conn is read-only."""
    print("=" * 70)
    print("Migration {}: {}".format(MIGRATION_ID, DESCRIPTION))
    print("=" * 70)
    # TODO: query the current state and print what would change.
    print("(fill in _describe_plan to summarize the planned changes)")
    print()
    print("Dry run complete. No writes performed.")


def _perform_changes(conn: sqlite3.Connection) -> None:
    """Run the migration's writes against the open connection.

    The caller has already:
      - opened the connection with ``isolation_level=None``
      - issued ``BEGIN``
      - confirmed the migration is not already applied

    Do not commit or rollback here. The caller owns the transaction so
    it can call ``runner.record(...)`` afterwards and commit both in
    one shot.
    """
    # TODO: replace with the actual migration writes.
    # Example: conn.execute("ALTER TABLE foo ADD COLUMN bar TEXT")
    raise NotImplementedError(
        "Fill in _perform_changes for migration {}".format(MIGRATION_ID)
    )


# ----------------------------------------------------------------------
# Apply
# ----------------------------------------------------------------------

def apply_migration(db_path: str, runner: MigrationRunner) -> int:
    """Run the migration inside a single transaction.

    Returns the exit code.
    """
    conn = sqlite3.connect(db_path, isolation_level=None)
    conn.row_factory = sqlite3.Row
    try:
        conn.execute("BEGIN")
        try:
            _perform_changes(conn)
            runner.record(MIGRATION_ID, DESCRIPTION, conn)
            conn.execute("COMMIT")
            return EXIT_OK
        except sqlite3.IntegrityError as exc:
            # ``record`` raises this when migration_id is already
            # present — which can happen in a race or if someone
            # bypassed is_applied(). Treat as already-applied.
            try:
                conn.execute("ROLLBACK")
            except sqlite3.Error:
                pass
            print("Migration {} already recorded — nothing to do "
                  "({}).".format(MIGRATION_ID, exc), file=sys.stderr)
            return EXIT_OK
        except sqlite3.Error as exc:
            try:
                conn.execute("ROLLBACK")
            except sqlite3.Error:
                pass
            print("ERROR: SQLite error: {}".format(exc), file=sys.stderr)
            print("Transaction rolled back. DB is unchanged from before "
                  "this run.", file=sys.stderr)
            return EXIT_SQLITE_ERROR
    finally:
        conn.close()


# ----------------------------------------------------------------------
# Entry point
# ----------------------------------------------------------------------

def _build_parser() -> _Parser:
    parser = _Parser(description=DESCRIPTION)
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--dry-run", action="store_true",
                      help="Preview the migration without touching the "
                           "DB (default).")
    mode.add_argument("--apply", action="store_true",
                      help="Apply the migration after creating a "
                           "backup. Refuses to run if the print-farm "
                           "service is up.")
    parser.add_argument("--db-path", default=DEFAULT_DB_PATH,
                        help="Path to the target DB "
                             "(default: {}).".format(DEFAULT_DB_PATH))
    return parser


def main(argv: Optional[Sequence[str]] = None) -> int:
    parser = _build_parser()
    args = parser.parse_args(argv)

    db_path = args.db_path
    if not os.path.exists(db_path):
        print("ERROR: DB not found at {}".format(db_path), file=sys.stderr)
        return EXIT_BAD_ARGS

    runner = MigrationRunner(db_path)
    runner.ensure_schema_version_table()

    if runner.is_applied(MIGRATION_ID):
        print("Migration {} already applied. Nothing to do.".format(
            MIGRATION_ID))
        return EXIT_OK

    if not args.apply:
        # Default branch — dry-run.
        conn = sqlite3.connect("file:{}?mode=ro".format(db_path), uri=True)
        conn.row_factory = sqlite3.Row
        try:
            _describe_plan(conn)
        finally:
            conn.close()
        return EXIT_OK

    # --apply path
    if is_service_running():
        print("ERROR: print-farm-monitor appears to be running "
              "(port 5001 is bound).", file=sys.stderr)
        print("Stop the service first:", file=sys.stderr)
        print("  sudo systemctl stop print-farm-monitor", file=sys.stderr)
        return EXIT_SERVICE_RUNNING

    # Step 0: whole-fleet defensive snapshot before any write.
    # See "Two-layer backup" in the module docstring — this snapshot
    # captures EVERY DB; ``create_backup`` below captures only this
    # migration's primary target. Both layers are required.
    settings = load_settings()
    snap_result = snapshot_all_dbs(
        settings, reason="pre-migration-{}".format(MIGRATION_ID)
    )
    print("[snapshot] {} DBs -> {}".format(
        snap_result.db_count, snap_result.path))

    try:
        backup_path = create_backup(db_path)
    except (OSError, FileExistsError) as exc:
        print("ERROR: backup failed: {}".format(exc), file=sys.stderr)
        print("DB has not been modified.", file=sys.stderr)
        return EXIT_BACKUP_FAILED
    print("Backup created: {}".format(backup_path))

    return apply_migration(db_path, runner)


if __name__ == "__main__":
    sys.exit(main())
